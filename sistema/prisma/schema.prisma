// KTV Working Drone — Sistema Comercial
// Modelo de datos: Familia 1 (servicios puntuales) y Familia 2 (KTV Care) como
// entidades SEPARADAS, unidas por Cotizacion. Ver KWD-SIS-PROMPT-001 v2.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  COMERCIAL
  DIRECTOR_COMERCIAL
  GERENCIA
}

enum Familia {
  PUNTUAL
  CARE
}

enum EstadoCotizacion {
  BORRADOR
  PENDIENTE_APROBACION
  APROBADA
  RECHAZADA
  ENVIADA
}

enum ServicioPuntual {
  INSPECCION_SOLA
  LAVADO_MAS_INSPECCION
  SOLO_LAVADO
}

enum TipoInforme {
  DIAGNOSTICO_VISUAL
  INTERNACIONAL
}

enum Superficie {
  VIDRIO
  MIXTA
  DIFICIL
}

enum NivelRecargo {
  BAJO
  MEDIO
  ALTO
}

enum PlanCare {
  INSPECT
  ESSENTIAL
  COMPLETE
}

enum FormaPago {
  CONTADO
  DIFERIDO_12
}

enum TipoItemTercero {
  PRODUCTO
  SERVICIO
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)
  creadoAt     DateTime @default(now())

  // "Olvidé mi contraseña": token de un solo uso enviado por correo, con
  // vencimiento corto. Null cuando no hay solicitud de recuperación pendiente.
  resetToken           String?   @unique
  resetTokenExpiresAt  DateTime?

  cotizacionesCreadas  Cotizacion[] @relation("CreadoPor")
  cotizacionesAprobadas Cotizacion[] @relation("AprobadoPor")
  auditorias           Auditoria[]
}

// Parámetros editables por Gerencia — nunca hardcodeados en el motor.
model Parametro {
  clave          String   @id
  valor          String   // guardado como texto, se castea según unidad en el motor
  unidad         String
  actualizadoPor String?
  actualizadoAt  DateTime @updatedAt
}

model ClienteProspecto {
  id                 String   @id @default(cuid())
  nombre             String
  empresa            String?
  contacto           String?
  canalOrigen        String?
  pipedrivePersonId  String?
  pipedriveDealId    String?
  creadoAt           DateTime @default(now())

  cotizaciones Cotizacion[]
}

// Entidad común a las 2 familias — nunca se mezclan los datos de una y otra.
model Cotizacion {
  id                 String            @id @default(cuid())
  idTrazabilidad     String            @unique // el que ve el cliente en el documento (KTV-YYYYMMDD-NNNN)
  // Módulo 2 — presentador: el link público usa este token NO adivinable
  // (el idTrazabilidad es secuencial por fecha, sería enumerable por terceros).
  linkToken          String            @unique @default(cuid())
  linkActivo         Boolean           @default(true)
  familia            Familia
  clienteId          String
  cliente            ClienteProspecto  @relation(fields: [clienteId], references: [id])
  creadoPorId        String
  creadoPor          Usuario           @relation("CreadoPor", fields: [creadoPorId], references: [id])
  estado             EstadoCotizacion  @default(BORRADOR)
  requiereAprobacion Boolean           @default(false)
  aprobadoPorId      String?
  aprobadoPor        Usuario?          @relation("AprobadoPor", fields: [aprobadoPorId], references: [id])
  aprobadoAt         DateTime?
  enviadoAt          DateTime?
  vigenteHasta       DateTime?
  snapshotParametros String            // JSON congelado en el momento de generar (foto congelada)
  totalCliente       Float             // único número que ve el cliente (+ mensual si aplica, en CotizacionCare)
  observaciones       String?

  aceptadaPorCliente Boolean  @default(false)
  aceptadaAt         DateTime?

  creadoAt DateTime @default(now())

  // Corrección de una cotización ya enviada/aprobada/rechazada (nunca se edita
  // en el mismo registro fuera de Borrador — se desactiva el link viejo y se
  // crea esta como versión nueva, ligada a la anterior). Único por anterior:
  // cada versión solo se corrige una vez — para volver a corregir, se corrige
  // la versión más reciente, no la original.
  versionAnteriorId String?     @unique
  versionAnterior   Cotizacion? @relation("VersionDeCorreccion", fields: [versionAnteriorId], references: [id])
  versionNueva      Cotizacion? @relation("VersionDeCorreccion")

  puntual        CotizacionPuntual?
  care           CotizacionCare?
  auditorias     Auditoria[]
  aperturas      Apertura[]
  ordenServicio  OrdenServicio?
  itemsTerceros  ItemTercero[]
}

// ============ FAMILIA 1 — Servicios puntuales (no recurrentes) ============
model CotizacionPuntual {
  id            String     @id @default(cuid())
  cotizacionId  String     @unique
  cotizacion    Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  servicio                    ServicioPuntual
  tipoInformeBase             TipoInforme?     // el informe que va en la línea base (null si SOLO_LAVADO)
  mostrarInformeInternacional Boolean          @default(false) // REGLA B: por cotización

  // --- Solo interno: nunca se imprime en el documento del cliente ---
  m2Fachada       Float?
  superficie      Superficie?
  tipoEdificio    NivelRecargo?
  dificultad      NivelRecargo?
  ciudadFuera     Boolean       @default(false)
  movilizacion    Float         @default(0)
  rangoTecho      Float?

  diasOperacion   Float?
  costoOperacion  Float?   // costo interno del lavado y/o inspección
  feeNoruega      Float?   // CONFIDENCIAL — Regla A, nunca sale de acá
  margenPct       Float?   // CONFIDENCIAL — Regla A

  // Descuento manual sobre el lavado (Gerencia 2026-07-17) — SIEMPRE dispara
  // aprobación de Gerencia y nunca puede bajar el margen general de 35%
  // (piso más estricto que el 25% de excepciones automáticas por dificultad).
  descuentoPct           Float?  // 0-99, % aplicado sobre el precio de lista del lavado
  precioLavadoSinDescuento Float? // CONFIDENCIAL — Regla A, referencia interna del precio antes del descuento

  precioLavado           Float? // sin IVA
  precioInformeBase      Float? // sin IVA (DV o Internacional, según tipoInformeBase)
  precioInformeAdicional Float? // sin IVA (Internacional cuando es adicional, no base)

  // --- Campos manuales del comercial (varían por operación) ---
  anticipoPct       Int?
  saldoPct          Int?
  condicionPagoNota String?
  permisoAerocivil  String?
  ejecucionSitio    String?
}

// ============ FAMILIA 2 — KTV Care (programas recurrentes) ============
// Regla Gerencia 2026-07-13: los 3 paquetes (Inspect/Essential/Complete) se
// calculan y se muestran SIEMPRE juntos al cliente, como comparación — nunca
// uno solo. planRecomendado es únicamente cuál lleva la insignia "RECOMENDADO".
model CotizacionCare {
  id           String     @id @default(cuid())
  cotizacionId String     @unique
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  planRecomendado PlanCare
  contratoAnios   Int       @default(1)
  formaPago       FormaPago @default(CONTADO)

  m2Fachada  Float?  // solo interno
  rangoTecho Float?  // solo interno
  // Corrección 2026-07-16: calcularCare nunca recibía estas variables — el costo
  // (y ahora el precio) de las lavadas de Care siempre asumía MIXTA/BAJO/BAJO,
  // sin importar el edificio real. Mismo hueco de margen que ya se corrigió en
  // el lavado de Familia 1 (ver calcularLavado).
  superficie   Superficie?   // solo interno
  tipoEdificio NivelRecargo? // solo interno
  dificultad   NivelRecargo? // solo interno

  valorAnualInspect     Float
  valorMensualInspect   Float
  valorAnualEssential   Float
  valorMensualEssential Float
  valorAnualComplete    Float
  valorMensualComplete  Float
}

// Ítem de Tercero (spec_items_terceros_20260716_2.md): producto o servicio
// subcontratado y revendido con margen fijo, facturado bajo el nombre de KTV.
// Genérico y aplicable a cualquier familia — no es catálogo fijo por caso.
model ItemTercero {
  id                 String          @id @default(cuid())
  cotizacionId       String
  cotizacion         Cotizacion      @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  descripcionCliente String          // visible al cliente — nunca debe mencionar "tercero"/"subcontratado"
  notaInterna        String?         // CONFIDENCIAL — Regla A, para control contable de Gerencia
  tipo               TipoItemTercero
  costoReal          Float           // CONFIDENCIAL — Regla A, lo que KTV le paga al tercero
  margenNetoDeseado  Float           // CONFIDENCIAL — Regla A, 0.15 (producto) o 0.25 (servicio)
  precioVenta        Float           // lo único de este ítem que ve el cliente

  creadoAt DateTime @default(now())
}

// Orden de Servicio Comercial interna para Operaciones — NUNCA lleva cifras.
model OrdenServicio {
  id           String     @id @default(cuid())
  cotizacionId String     @unique
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  anticipoConfirmado Boolean @default(false)
  notasOperativas    String?
  creadoAt     DateTime @default(now())
}

model Auditoria {
  id           String     @id @default(cuid())
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  usuarioId    String
  usuario      Usuario    @relation(fields: [usuarioId], references: [id])
  accion       String     // creo | edito | aprobo | rechazo | envio | acepto_cliente
  detalle      String?
  timestamp    DateTime   @default(now())
}

model Apertura {
  id           String     @id @default(cuid())
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  userAgent    String?    // referencia del dispositivo/navegador del cliente
  timestamp    DateTime   @default(now())
}
